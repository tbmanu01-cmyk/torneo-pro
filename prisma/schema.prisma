generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── Enums ────────────────────────────────────────────────────────────────────

enum Role {
  SUPER_ADMIN
  ADMIN_TORNEO
  ASISTENTE
  CAPITAN
  ESPECTADOR
}

enum FormatoTorneo {
  LIGA
  ELIMINACION_DIRECTA
  IDA_VUELTA
}

enum EstadoTorneo {
  PENDIENTE
  EN_CURSO
  FINALIZADO
}

enum EstadoPago {
  PENDIENTE
  PARCIAL
  PAGADO
  BLOQUEADO
}

enum EstadoJornada {
  PENDIENTE
  EN_CURSO
  FINALIZADA
}

enum EstadoPartido {
  PENDIENTE
  EN_CURSO
  FINALIZADO
  SUSPENDIDO
}

enum TipoEvento {
  GOL
  TARJETA_AMARILLA
  TARJETA_ROJA
  CAMBIO
}

enum EstadoComprobante {
  PENDIENTE
  APROBADO
  RECHAZADO
}

// ─── Models ───────────────────────────────────────────────────────────────────

model User {
  id            String   @id @default(cuid())
  email         String   @unique
  password      String
  name          String
  role          Role     @default(ESPECTADOR)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  torneosAdmin  Torneo[]  @relation("AdminTorneos")
  equipoCapitan Equipo[]  @relation("CapitanEquipos")
  clubCapitan   Club[]    @relation("CapitanClubs")
  actasCerradas Partido[] @relation("ActasCerradas")
  pagosAprobados Pago[]   @relation("PagosAprobados")

  @@map("users")
}

model Club {
  id         String   @id @default(cuid())
  nombre     String
  logo       String?
  ciudad     String?
  capitanId  String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  capitan User?    @relation("CapitanClubs", fields: [capitanId], references: [id])
  equipos Equipo[]

  @@map("clubs")
}

model Torneo {
  id               String        @id @default(cuid())
  nombre           String
  descripcion      String?
  logo             String?
  formato          FormatoTorneo
  estado           EstadoTorneo  @default(PENDIENTE)
  puntosVictoria   Int           @default(3)
  puntosEmpate     Int           @default(1)
  puntosDerrota    Int           @default(0)
  edicion          Int           @default(1)
  fechaInicio      DateTime?
  fechaFin         DateTime?
  adminId          String
  torneoOriginalId String?
  createdAt        DateTime      @default(now())
  updatedAt        DateTime      @updatedAt

  admin               User                 @relation("AdminTorneos", fields: [adminId], references: [id])
  torneoOriginal      Torneo?              @relation("TorneoClones", fields: [torneoOriginalId], references: [id])
  clones              Torneo[]             @relation("TorneoClones")
  equipos             Equipo[]
  jornadas            Jornada[]
  configuracionPago   ConfiguracionPago?
  pagos               Pago[]

  @@map("torneos")
}

model Equipo {
  id         String     @id @default(cuid())
  nombre     String
  logo       String?
  torneoId   String
  clubId     String?
  capitanId  String?
  estadoPago EstadoPago @default(PENDIENTE)
  createdAt  DateTime   @default(now())
  updatedAt  DateTime   @updatedAt

  torneo            Torneo          @relation(fields: [torneoId], references: [id], onDelete: Cascade)
  club              Club?           @relation(fields: [clubId],  references: [id])
  capitan           User?           @relation("CapitanEquipos", fields: [capitanId], references: [id])
  jugadores         Jugador[]
  partidosLocal     Partido[]       @relation("PartidosLocal")
  partidosVisitante Partido[]       @relation("PartidosVisitante")
  eventos           EventoPartido[]
  pagos             Pago[]

  @@map("equipos")
}

model Jugador {
  id                String   @id @default(cuid())
  nombre            String
  numeroJugador     Int
  equipoId          String
  tarjetasAmarillas Int      @default(0)
  tarjetasRojas     Int      @default(0)
  suspendido        Boolean  @default(false)
  goles             Int      @default(0)
  asistencias       Int      @default(0)
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  equipo            Equipo          @relation(fields: [equipoId], references: [id], onDelete: Cascade)
  eventos           EventoPartido[] @relation("EventosJugador")
  eventosAsistencia EventoPartido[] @relation("AsistenciaEventos")

  @@map("jugadores")
}

model Jornada {
  id        String        @id @default(cuid())
  numero    Int
  torneoId  String
  nombre    String
  fecha     DateTime?
  estado    EstadoJornada @default(PENDIENTE)
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt

  torneo   Torneo    @relation(fields: [torneoId], references: [id], onDelete: Cascade)
  partidos Partido[]

  @@map("jornadas")
}

model Partido {
  id                String        @id @default(cuid())
  jornadaId         String
  equipoLocalId     String?
  equipoVisitanteId String?
  golesLocal        Int           @default(0)
  golesVisitante    Int           @default(0)
  fecha             DateTime?
  hora              String?
  cancha            String?
  estado            EstadoPartido @default(PENDIENTE)
  actaCerrada       Boolean       @default(false)
  cerradaPorId      String?
  fechaCierre       DateTime?
  createdAt         DateTime      @default(now())
  updatedAt         DateTime      @updatedAt

  jornada         Jornada         @relation(fields: [jornadaId],         references: [id], onDelete: Cascade)
  equipoLocal     Equipo?         @relation("PartidosLocal",     fields: [equipoLocalId],     references: [id])
  equipoVisitante Equipo?         @relation("PartidosVisitante", fields: [equipoVisitanteId], references: [id])
  cerradaPor      User?           @relation("ActasCerradas",     fields: [cerradaPorId],      references: [id])
  eventos         EventoPartido[]

  @@map("partidos")
}

model EventoPartido {
  id                  String     @id @default(cuid())
  partidoId           String
  tipo                TipoEvento
  jugadorId           String
  equipoId            String
  minuto              Int        @default(0)
  asistenciaJugadorId String?
  notas               String?
  createdAt           DateTime   @default(now())

  partido           Partido  @relation(fields: [partidoId], references: [id], onDelete: Cascade)
  jugador           Jugador  @relation("EventosJugador",     fields: [jugadorId],           references: [id])
  equipo            Equipo   @relation(fields: [equipoId],  references: [id])
  asistenciaJugador Jugador? @relation("AsistenciaEventos", fields: [asistenciaJugadorId], references: [id])

  @@map("eventos_partido")
}

model ConfiguracionPago {
  id                      String    @id @default(cuid())
  torneoId                String    @unique
  montoInscripcion        Float
  moneda                  String    @default("VES")
  permiteCuotas           Boolean   @default(false)
  numeroCuotas            Int?
  montoPrimeraCuota       Float?
  montoSegundaCuota       Float?
  fechaLimitePrimeraCuota DateTime?
  fechaLimiteSegundaCuota DateTime?
  datosPagoMovil          Json
  instrucciones           String?
  createdAt               DateTime  @default(now())
  updatedAt               DateTime  @updatedAt

  torneo Torneo @relation(fields: [torneoId], references: [id], onDelete: Cascade)

  @@map("configuraciones_pago")
}

model Pago {
  id              String            @id @default(cuid())
  equipoId        String
  torneoId        String
  monto           Float
  numeroCuota      Int               @default(1)
  numeroReferencia String?
  comprobante      String
  estado           EstadoComprobante @default(PENDIENTE)
  motivoRechazo   String?
  aprobadoPorId   String?
  fechaAprobacion DateTime?
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt

  equipo      Equipo @relation(fields: [equipoId],   references: [id], onDelete: Cascade)
  torneo      Torneo @relation(fields: [torneoId],   references: [id], onDelete: Cascade)
  aprobadoPor User?  @relation("PagosAprobados",     fields: [aprobadoPorId], references: [id])

  @@map("pagos")
}
